{
    "system": {
        "name": "Q-Pilot",
        "version": "1.0.0",
        "description": "Quantum-Enhanced Vehicle Trajectory Prediction System"
    },
    "data": {
        "sequence_length": 5,
        "prediction_length": 3,
        "features": [
            "x_position",
            "y_position",
            "velocity",
            "acceleration",
            "steering_angle",
            "lane_id"
        ],
        "feature_descriptions": {
            "x_position": "Vehicle x-coordinate position",
            "y_position": "Vehicle y-coordinate position",
            "velocity": "Vehicle speed in m/s",
            "acceleration": "Vehicle acceleration in m/s²",
            "steering_angle": "Steering wheel angle in radians",
            "lane_id": "Current lane identifier"
        }
    },
    "models": {
        "classical": {
            "linear_regression": {
                "enabled": true,
                "description": "Baseline linear model"
            },
            "lstm": {
                "enabled": true,
                "hidden_dim": 64,
                "num_layers": 2,
                "dropout": 0.2,
                "description": "Primary classical model"
            },
            "random_forest": {
                "enabled": true,
                "n_estimators": 100,
                "description": "Ensemble tree-based model"
            }
        },
        "quantum": {
            "enabled": true,
            "num_qubits": 4,
            "encoding_type": "ry",
            "circuit_type": "variational",
            "description": "Variational Quantum Circuit model"
        }
    },
    "training": {
        "batch_size": 32,
        "epochs": 50,
        "learning_rate": 0.001,
        "validation_split": 0.15,
        "test_split": 0.15,
        "early_stopping": {
            "patience": 10,
            "min_delta": 0.001
        }
    },
    "evaluation": {
        "metrics": [
            "MSE",
            "RMSE",
            "R2",
            "ADE",
            "FDE"
        ],
        "visualization": {
            "plot_predictions": true,
            "plot_metrics": true,
            "plot_distributions": true
        }
    },
    "dashboard": {
        "port": 8501,
        "host": "localhost",
        "demo_mode": true,
        "auto_reload": true
    },
    "paths": {
        "data": "../data",
        "models": "../models",
        "training_logs": "../training",
        "evaluation_results": "../evaluation",
        "research_papers": "../research_module/papers"
    }
}